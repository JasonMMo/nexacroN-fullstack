<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nexacro.uiadapter.mapper.LargeDataMapper">

    <!--
      Canonical TB_LARGE columns: LARGE_ID, NAME, REG_DATE, STORY, STATUS.
      The category parameter from the controller is preserved at the call-chain
      level for compatibility but is ignored here (canonical has no CATEGORY column).
    -->

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM TB_LARGE
    </select>

    <select id="page" resultType="com.nexacro.uiadapter.domain.LargeData">
        SELECT LARGE_ID, NAME, REG_DATE, STORY, STATUS
        FROM TB_LARGE
        ORDER BY LARGE_ID
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

</mapper>
