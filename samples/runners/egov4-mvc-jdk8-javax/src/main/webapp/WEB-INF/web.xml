<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>mvc-jdk8-javax uiadapter runner</display-name>

    <!-- XENI export/import + monitor parameters (canonical javax-example) -->
    <context-param>
        <param-name>export-path</param-name>
        <param-value>/excel</param-value>
    </context-param>
    <context-param>
        <param-name>import-path</param-name>
        <param-value>/excel</param-value>
    </context-param>
    <context-param>
        <param-name>monitor-enabled</param-name>
        <param-value>true</param-value>
    </context-param>
    <context-param>
        <param-name>monitor-cycle-time</param-name>
        <param-value>30</param-value>
    </context-param>
    <context-param>
        <param-name>file-storage-time</param-name>
        <param-value>10</param-value>
    </context-param>

    <!-- utf-8 encoding for *.do requests -->
    <filter>
        <filter-name>encodingFilter</filter-name>
        <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>utf-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <url-pattern>*.do</url-pattern>
    </filter-mapping>

    <!-- Root application context: explicit XML files loaded in order so that
         DataSource is created before context-initialize.xml's DataSourceInitializer runs.
         Default XmlWebApplicationContext is used (no contextClass override). -->
    <context-param>
        <param-name>contextConfigLocation</param-name>
        <param-value>
            classpath:spring/context-common.xml
            classpath:spring/context-datasource.xml
            classpath:spring/context-transaction.xml
            classpath:spring/context-mapper.xml
            classpath:spring/context-nexacro.xml
            classpath:spring/context-relay.xml
            classpath:spring/context-initialize.xml
        </param-value>
    </context-param>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <listener>
        <listener-class>org.springframework.web.context.ContextLoaderListener</listener-class>
    </listener>

    <!-- DispatcherServlet "action" — handles *.do, loads dispatcher-servlet.xml.
         Multipart-config is declared at servlet level so StandardServletMultipartResolver
         (declared in dispatcher-servlet.xml) can resolve parts. -->
    <servlet>
        <servlet-name>action</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
        <init-param>
            <param-name>contextConfigLocation</param-name>
            <param-value>/WEB-INF/config/springmvc/dispatcher-servlet.xml</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
        <multipart-config>
            <location>${java.io.tmpdir}</location>
            <max-file-size>52428800</max-file-size>
            <max-request-size>104857600</max-request-size>
            <file-size-threshold>1048576</file-size-threshold>
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>action</servlet-name>
        <url-pattern>*.do</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
