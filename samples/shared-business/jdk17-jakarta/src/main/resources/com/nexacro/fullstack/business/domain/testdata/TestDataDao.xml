<mapper namespace="com.nexacro.fullstack.business.domain.testdata.TestDataDao">

    <select id="selectAll" resultType="map">
        SELECT
            ID,
            STRING_VALUE,
            INT_VALUE,
            BOOLEAN_VALUE,
            LONG_VALUE,
            FLOAT_VALUE,
            DOUBLE_VALUE,
            BIG_DECIMAL_VALUE,
            DATE_VALUE,
            TIME_VALUE,
            DATETIME_VALUE,
            BYTES_VALUE
        FROM TB_TEST_DATA_TYPE
        ORDER BY ID
    </select>

</mapper>
