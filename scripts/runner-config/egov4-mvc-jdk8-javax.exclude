# egov4-mvc-jdk8-javax.exclude
# WAR runner, javax lane, eGov 4 + MVC (no Boot) / JDK 8.
# Union of WAR + eGov + library-gap exclusions.

# WAR: no Boot entry point, no Boot-only config; protect WAR layout.
- Application.java
- src/main/java/com/nexacro/uiadapter/config/
P src/main/webapp/
P src/main/resources/spring/
P src/main/resources/message/

# eGov: preserve egovframework source and resources.
P src/main/java/egovframework/
P src/main/resources/egovframework/

# Library capability gaps: uiadapter-spring-core 1.4.x lacks NexacroStreamResult / @ExcludeField.
- src/main/java/com/nexacro/uiadapter/controller/StreamController.java
P src/main/java/com/nexacro/uiadapter/controller/StreamController.java
- src/main/java/com/nexacro/uiadapter/domain/Board.java
P src/main/java/com/nexacro/uiadapter/domain/Board.java
